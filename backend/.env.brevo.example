PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/mailservice
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
JWT_SECRET=replace-with-strong-secret
VERIFICATION_TOKEN_TTL_MIN=30
OTP_TTL_MIN=5
OTP_COOLDOWN_SEC=60
OTP_DAILY_LIMIT=10

# Brevo SMTP settings
# MAIL_FROM must use a sender email/domain verified in Brevo.
MAIL_FROM="Mail Service <verified-sender@example.com>"
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
